{
  "name": "nexogestao",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.30.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "api:dev": "pnpm --filter ./apps/api dev",
    "api:build": "pnpm --filter ./apps/api build",
    "web:dev": "pnpm --filter ./apps/web dev",
    "web:build": "pnpm --filter ./apps/web build"
  },
  "devDependencies": {
    "prisma": "5.22.0",
    "turbo": "^2.0.0"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.9.3"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "@scarf/scarf",
      "@sentry/profiling-node",
      "bcrypt",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "unrs-resolver",
      "xxhash"
    ]
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@trpc/server": "11.15.0"
  }
}
