{
  "name": "nexogestao",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.30.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "./scripts/dev-full.sh",
    "prisma:generate": "pnpm --filter ./apps/api prisma:generate",
    "prisma:migrate:deploy": "pnpm --filter ./apps/api prisma:migrate:deploy",
    "prisma:check": "node scripts/check-prisma-client.mjs",
    "db:smoke:operational-actions": "node scripts/check-operational-actions-db.mjs",
    "smoke:operational-actions:diagnostics": "node scripts/smoke-operational-actions-diagnostics.mjs",
    "ci:preflight": "pnpm prisma:check && pnpm -r typecheck && pnpm -s build && pnpm --filter ./apps/api test && pnpm --filter ./apps/web test",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "api:dev": "pnpm --filter ./apps/api dev",
    "api:build": "pnpm --filter ./apps/api build",
    "web:dev": "pnpm --filter ./apps/web dev:bff",
    "web:build": "pnpm --filter ./apps/web build",
    "dev:full": "./scripts/dev-full.sh",
    "dev:reset": "NEXO_DEV_RESET=1 NEXO_DEV_KILL_PORTS=1 ./scripts/dev-full.sh",
    "dev:infra": "docker compose -f docker-compose.yml up -d postgres redis",
    "dev:api": "API_PORT=3000 PORT=3000 pnpm --filter ./apps/api run dev",
    "dev:web": "PORT=3010 NEXO_API_URL=http://127.0.0.1:3000 pnpm --filter ./apps/web run dev",
    "web:dev:bff": "pnpm --filter ./apps/web dev:bff",
    "web:dev:client": "pnpm --filter ./apps/web dev:client",
    "dev:doctor": "./scripts/doctor.sh",
    "dev:ports": "./scripts/dev-ports.sh",
    "dev:health": "./scripts/dev-health.sh",
    "dev:logs": "./scripts/dev-logs.sh",
    "test:tenant:isolation": "docker compose -f docker-compose.yml up -d postgres redis && RUN_REAL_INTEGRATION=true pnpm --filter ./apps/api test -- test/integration/canonical-operational-workflow.spec.ts",
    "test:dev-full-ports": "./scripts/test-dev-full-ports.sh"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "prisma": "5.22.0",
    "tsx": "^4.19.2",
    "turbo": "^2.0.0"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.9.3"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "@scarf/scarf",
      "@sentry/profiling-node",
      "bcrypt",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@trpc/server": "11.15.0"
  }
}
