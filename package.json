{
  "name": "nexogestao",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.30.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "./scripts/dev-full.sh",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "api:dev": "pnpm --filter ./apps/api dev",
    "api:build": "pnpm --filter ./apps/api build",
    "web:dev": "pnpm --filter ./apps/web dev:bff",
    "web:build": "pnpm --filter ./apps/web build",
    "dev:full": "./scripts/dev-full.sh",
    "dev:reset": "NEXO_DEV_RESET=1 NEXO_KILL_STALE_DEV_PROCESSES=1 ./scripts/dev-full.sh",
    "dev:infra": "docker compose up -d postgres redis",
    "dev:api": "API_PORT=3000 PORT=3000 pnpm --filter ./apps/api run dev",
    "dev:web": "PORT=3010 NEXO_API_URL=http://127.0.0.1:3000 pnpm --filter ./apps/web run dev",
    "web:dev:bff": "pnpm --filter ./apps/web dev:bff",
    "web:dev:client": "pnpm --filter ./apps/web dev:client"
  },
  "prisma": {
    "seed": "tsx prisma/seed-pilot.ts"
  },
  "devDependencies": {
    "prisma": "5.22.0",
    "tsx": "^4.19.2",
    "turbo": "^2.0.0"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.9.3"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "@scarf/scarf",
      "@sentry/profiling-node",
      "bcrypt",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@trpc/server": "11.15.0"
  }
}
