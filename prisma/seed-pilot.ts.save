  const org = await prisma.organization.upsert({
    where: { slug: pilotOrgSlug },
    update: {
      name: pilotOrgName,
      requiresOnboarding: false,
      timezone: 'America/Sao_Paulo',
      currency: 'BRL',
    },
    create: {
      slug: pilotOrgSlug,
      name: pilotOrgName,
