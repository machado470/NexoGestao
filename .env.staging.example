# ============================================================
# NexoGestão — Variáveis de Ambiente de STAGING
# ============================================================
# Copie este arquivo para .env.staging e preencha os valores.
#
#   cp .env.staging.example .env.staging
#   nano .env.staging
#
# ATENÇÃO: NUNCA comite o arquivo .env.staging no repositório!
# ============================================================

# ─── Domínio e Infraestrutura ────────────────────────────────
# Domínio do staging (sem protocolo, sem barra final)
# Exemplo: staging.nexogestao.com.br
DOMAIN=staging.seudominio.com.br

# E-mail para registro do certificado Let's Encrypt (staging)
EMAIL=admin-staging@seudominio.com.br

# ─── Banco de Dados (PostgreSQL) ─────────────────────────────
POSTGRES_USER=nexo_staging
POSTGRES_PASSWORD=TROQUE_POR_SENHA_STAGING_AQUI
POSTGRES_DB=nexogestao_staging
POSTGRES_PORT=5433

# URL completa de conexão
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public

# ─── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=TROQUE_POR_SENHA_REDIS_STAGING

# ─── Autenticação JWT ────────────────────────────────────────
# Gere com: openssl rand -base64 64
JWT_SECRET=TROQUE_POR_STRING_ALEATORIA_STAGING
JWT_EXPIRES_IN=1h

# ─── API ─────────────────────────────────────────────────────
API_PORT=3001
NODE_ENV=staging

# URLs de CORS (separadas por vírgula)
CORS_ORIGINS=https://app-staging.seudominio.com.br,http://localhost:3000

# URL pública do frontend (usada nos redirects do Stripe)
FRONTEND_URL=https://app-staging.seudominio.com.br

# ─── Frontend (Vite) ─────────────────────────────────────────
VITE_API_URL=/api

# ─── Stripe (Pagamentos) — Modo TEST ─────────────────────────
# Chave secreta do Stripe (modo test: sk_test_...)
STRIPE_SECRET_KEY=sk_test_TROQUE_PELA_CHAVE_TEST

# Segredo do webhook do Stripe (staging)
STRIPE_WEBHOOK_SECRET=whsec_TROQUE_PELO_SEGREDO_TEST

# Price IDs dos planos no Stripe (test mode)
STRIPE_PRICE_STARTER=price_TROQUE_PELO_ID_TEST_STARTER
STRIPE_PRICE_PRO=price_TROQUE_PELO_ID_TEST_PRO
STRIPE_PRICE_BUSINESS=price_TROQUE_PELO_ID_TEST_BUSINESS

# ─── Sentry (Monitoramento) — Staging ────────────────────────
# DSN do projeto Sentry para staging (backend)
SENTRY_DSN_API=https://TROQUE@o0.ingest.sentry.io/0
SENTRY_DSN=https://TROQUE@o0.ingest.sentry.io/0

# DSN do projeto Sentry para staging (frontend)
VITE_SENTRY_DSN=https://TROQUE@o0.ingest.sentry.io/0

# Ambiente do Sentry
SENTRY_ENV=staging
SENTRY_ENVIRONMENT=staging
VITE_SENTRY_ENVIRONMENT=staging

# ─── E-mail (Resend) ─────────────────────────────────────────
RESEND_API_KEY=re_TROQUE_PELA_CHAVE_TEST
EMAIL_FROM=noreply-staging@seudominio.com.br

# ─── Backup (Opcional) ───────────────────────────────────────
BACKUP_RETENTION_DAYS=3
