# Variáveis de Ambiente para Staging - NexoGestão
# Copie este arquivo para .env.staging e preencha os valores.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nexogestao_staging
POSTGRES_PORT=5433
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/nexogestao_staging?schema=public"

# API
API_PORT=3001
NODE_ENV=production
JWT_SECRET="seu-jwt-secret-super-seguro-para-staging"
CORS_ORIGINS="http://localhost:3000"

# Para o entrypoint da API
AUTO_MIGRATE=1
DB_WAIT_SECONDS=40
# SEED_MODE=demo # Descomente para popular o banco com dados de demonstração

# Web
WEB_PORT=3000
NEXO_API_URL="http://localhost:3001"

# Sentry (Opcional)
# SENTRY_DSN_API="seu-dsn-do-sentry-para-api"
# SENTRY_DSN_WEB="seu-dsn-do-sentry-para-web"
